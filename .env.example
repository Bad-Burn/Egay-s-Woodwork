# Copy this file to .env.local and fill in your own values.
# Never commit .env.local (it is gitignored).

# MySQL Configuration
# IMPORTANT (hosting): "localhost" only works on your own machine. Vercel cannot
# reach a database on your PC -- you need a hosted MySQL (Railway, Aiven,
# PlanetScale, TiDB Cloud...) and its public host here, or the live site shows
# no artworks and the admin dashboard stays empty.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=art_gallery

# Managed providers (Aiven, etc.) refuse unencrypted connections. Leave unset
# for a local XAMPP/MySQL install; set to true for a hosted database.
# MYSQL_SSL=true
# Optional: paste the provider's CA certificate PEM to verify the server's
# identity as well as encrypt the traffic.
# MYSQL_SSL_CA=

# Cloudinary Configuration (https://cloudinary.com/console)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Authentication
# This is the ONLY thing protecting /admin/login, which is reachable by anyone
# who guesses the URL. Use a long, unique password -- never a common default.
ADMIN_PASSWORD=change_me

# Secret used to sign admin session cookies. Must be long and random.
# Generate one with: openssl rand -base64 48
# Use a DIFFERENT value in production than the one on your machine. Changing it
# instantly invalidates every existing session (useful if you get compromised).
AUTH_SECRET=generate_a_long_random_string

# Google Gemini AI (chatbot)
# Get a free key at https://aistudio.google.com/app/apikey
# Note: free-tier quota varies per model and per Google project. If the chatbot
# returns 500 with "Quota exceeded ... limit: 0", the model has no allowance on
# your key -- switch GEMINI_MODEL rather than assuming the key is bad.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
